   "source": [
    "df_blorearray = []\n",
    "    \n",
    "filePath = \"/Users/Vinod/Documents/NID/Sem 2/4. Information Visualization -1/3. Data Analysis/DataAnalytics/data/ERMS/\"\n",
    "\n",
    "df_wards_original = pd.read_csv(filePath+\"Assembly Ward Info.csv\",sep=\",\")\n",
    "df_constituency = df_wards_original.drop_duplicates(\"Constituency\")\n",
    "df_constituencyarray = []\n",
    "\n",
    "for constituency_ in df_constituency[\"Constituency\"]:\n",
    "    \n",
    "    df_wards = df_wards_original[df_wards_original[\"Constituency\"] == constituency_]\n",
    "    df_parts_original = pd.read_csv(filePath+\"booths.txt\",sep=\"\\t\")\n",
    "    \n",
    "    df_wardarray = []\n",
    "    for ward_no in df_wards[\"Ward_no\"]:\n",
    "        df_parts = df_parts_original[df_parts_original[\"Ward\"] == ward_no]\n",
    "\n",
    "        df_partarray = []\n",
    "        for part in df_parts[\"Part\"]:\n",
    "            df_voterdata = pd.read_csv(filePath+\"voterREC4Analysis/\"+part+\".txt\",sep=\"\\t\")\n",
    "            df_voterdata = df_voterdata[df_voterdata.columns[2:15]]\n",
    "            df_partarray.append(df_voterdata)\n",
    "        #print(str(ward_no)+\": \"+str(len(df_wardarray)))\n",
    "        df_wardarray.append(df_partarray)\n",
    "        \n",
    "    df_constituencyarray.append(df_wardarray)\n",
    "    \n",
    "df_blorearray.append(df_constituencyarray)\n",
    "\n",
    "print(\"done\")"
   ]
