    "#Attempt 0: Scatter-plot attempt\n",
    "\n",
    "filePath = \"/Users/Vinod/Documents/NID/Sem 2/4. Information Visualization -1/3. Data Analysis/Assignment/Plots/migrated/\"\n",
    "wards_geo = pd.read_csv(filePath+'Geo coordinates Wards.csv',sep=\",\")\n",
    "\n",
    "# Extract the data we're interested in\n",
    "lat, lon = wards_geo['latd'], wards_geo['longd']\n",
    "population = wards_geo['population']\n",
    "\n",
    "t=0\n",
    "for item in wards_geo['longd']:\n",
    "    wards_geo.set_value(t,'longd',int(item)*100)\n",
    "    t += 1\n",
    "\n",
    "# # Scatter the points, using size and color but no label\n",
    "plt.figure(figsize=(30,20))\n",
    "#plt.scatter(lon, lat, label=None,c=population, cmap='viridis',s=(area*1000), linewidth=0, alpha=0.5)\n",
    "xs = np.arange(len(lat))\n",
    "ys = [i+xs+(i*xs)**2 for i in lat]\n",
    "plt.scatter(lon, lat, label=None,cmap='viridis',c= cm.rainbow(np.linspace(0, 1, len(ys))), s=population, linewidth=0, alpha=0.5)\n",
    "plt.axis([5000,10000,10,40])\n",
    "#plt.colorbar(label='area')\n",
    "plt.xlabel(\"longitude\", fontsize=18)\n",
    "plt.ylabel(\"latitude\", fontsize=18);\n",
    "plt.title(\"Distribution of population over location\",fontsize=24)\n",
    "\n",
    "\n",
    "r=0\n",
    "for txt in wards_geo[\"ward\"]:\n",
    "    #plt.annotate(txt, (lon[r],lat[r]))\n",
    "    plt.annotate(\n",
    "        txt,\n",
    "        xy=(lon[r], lat[r]), xytext=(-20, 20),\n",
    "        textcoords='offset points', ha='right', va='bottom',\n",
    "        bbox=dict(boxstyle='round,pad=0.5', fc='yellow', alpha=0.5),\n",
    "        arrowprops=dict(arrowstyle = '->', connectionstyle='arc3,rad=0'))\n",
    "    r += 1\n"
