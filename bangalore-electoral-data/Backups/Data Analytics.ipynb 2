    "# Step2: Statistical analysis of basic missing/erroneous data, FOR ALL WARDS\n",
    "\n",
    "list_allwards_female = []\n",
    "list_allwards_male = []\n",
    "list_allwards_trans = []\n",
    "list_allwards_uniquevoters = []\n",
    "list_allwards_EPIC_blank = []\n",
    "list_allwards_EPIC_duplicate = []\n",
    "list_allwards_EPIC_multiple = []\n",
    "list_allwards_10plusvoters = []\n",
    "list_allwards_maxname = []\n",
    "\n",
    "for const in range(len(df_blore_wardwise[0])):\n",
    "    \n",
    "    for ward in range(len(df_blore_wardwise[0][const])):\n",
    "        \n",
    "        df_reqddata = df_blore_wardwise[0][const][ward]\n",
    "        df_reqddata = df_reqddata.drop_duplicates(subset=\"EPIC\", keep=False)\n",
    "        \n",
    "        # Count of voters segregated by genders:\n",
    "        df_females = df_reqddata[df_reqddata['Sex'] == 'F'].count()\n",
    "        list_allwards_female.append(df_females['Sex'])\n",
    "        \n",
    "        df_males = df_reqddata[df_reqddata['Sex'] == 'M'].count()\n",
    "        list_allwards_male.append(df_males['Sex'])\n",
    "        \n",
    "        df_trans = df_reqddata[(df_reqddata['Sex'] != 'M')&(df_reqddata['Sex'] != 'F')].count()\n",
    "        list_allwards_trans.append(df_trans['Sex'])\n",
    "        \n",
    "        voter_count = len(df_reqddata.index)\n",
    "        list_allwards_uniquevoters.append(voter_count)\n",
    "        \n",
    "        # EPIC number related analysis:\n",
    "        # No. of people with no EPIC:\n",
    "        EPIC_count = df_reqddata[\"EPIC\"].isnull().sum()\n",
    "        list_allwards_EPIC_blank.append(EPIC_count)\n",
    "        \n",
    "        # People with same EPIC number but different name and house.\n",
    "        df_duplicate_EPIC = df_reqddata[df_reqddata.duplicated(subset=\"EPIC\", keep=False)]\n",
    "        df_duplicate_EPIC = df_duplicate_EPIC[[\"Name\",\"EPIC\",\"House\",\"Status\"]].sort_values(\"EPIC\",ascending=True)\n",
    "        df_duplicate_EPIC = df_duplicate_EPIC.drop_duplicates(subset=\"House\", keep=False)\n",
    "        df_duplicate_EPIC = df_duplicate_EPIC.drop_duplicates(subset=\"Name\", keep=False)\n",
    "        list_allwards_EPIC_duplicate.append(df_duplicate_EPIC[\"EPIC\"].count())\n",
    "\n",
    "        # People with same metaphone/name and live in same home but different EPIC numbers. \n",
    "        # This implies 2 cards per person. Or, in other words, 2 votes per person.\n",
    "        # Further, a few ppl with this scenario are even related. For eg: Saloman is Sini's husband\n",
    "        df_duplicates = df_reqddata[df_reqddata.duplicated(subset=\"metaphone\", keep=False)].sort_values([\"metaphone\"])\n",
    "        df_house_multiple = df_duplicates[df_duplicates.duplicated(['House'], keep=False)]\n",
    "        df_house_multiple = df_house_multiple[df_house_multiple.columns[1:9]]\n",
    "        list_allwards_EPIC_multiple.append(df_house_multiple[\"EPIC\"].count())\n",
    "        \n",
    "        #10+ voters in same house.\n",
    "        df_same_house = df_reqddata.dropna().groupby('House').count() >= 10\n",
    "        df_same_house = df_same_house[df_same_house[\"Section\"]]\n",
    "        list_allwards_10plusvoters.append(len(df_same_house.index.tolist()))\n",
    "        \n",
    "        #Most common name & count\n",
    "        df_test = df_reqddata[\"Name\"].value_counts()\n",
    "        list_allwards_maxname.append(str(df_test.index[0])+\"-\"+str(df_test[0]))\n",
    "        \n",
    "        \n",
    "print('Done.')"
   ]
